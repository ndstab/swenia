# swenia environment — copy to `.env` for local use; NEVER commit the real .env.
#
# Local dev:   cp .env.example .env  &&  edit  &&  (the pipeline reads ANTHROPIC_API_KEY
#              from the environment — `export $(grep -v '^#' .env | xargs)` or just
#              `export ANTHROPIC_API_KEY=...` in your shell).
# Production:  do NOT use a .env file. Put ANTHROPIC_API_KEY in your repo's
#              GitHub Actions secrets (Settings → Secrets and variables → Actions).

# A REAL API key from console.anthropic.com → API keys. Starts with "sk-ant-api03-".
# NOT an OAuth/subscription token (sk-ant-oat...) — those fail as x-api-key.
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
